{
  "rules": {
    ".read": false,
    ".write": false,
    "confirmations": {
      "$confirmationId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['name', 'guestNames', 'guests', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
        },
        "guestNames": {
          ".validate": "newData.hasChildren(['0'])",
          "$index": {
            ".validate": "$index.matches(/^[0-4]$/) && newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
          }
        },
        "guests": {
          ".validate": "newData.isString() && newData.val().matches(/^(1|2|3|4|5)$/)"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
